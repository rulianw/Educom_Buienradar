@model WeatherViewModel

<div class="dropdown">
    <form method="get" action="/Weather">
        <select id="city-select" name="city" class="dropbtn" onchange="this.form.submit()">
            <option value="">-- Kies een stad --</option>
            @foreach (var city in Model.Cities)
            {
                if (!string.IsNullOrEmpty(Model.SelectedCity) &&
                    string.Equals(city, Model.SelectedCity, StringComparison.OrdinalIgnoreCase))
                {
                    <option value="@city" selected="selected">@city</option>
                }
                else
                {
                    <option value="@city">@city</option>
                }
            }
        </select>

        @* New — date pickers *@
        <div class="date-pickers">
            <label>Startdatum:
                <input type="date" name="startdatum" 
                       value="@Model.Startdatum.ToString("yyyy-MM-dd")" />
            </label>
            <label>Einddatum:
                <input type="date" name="einddatum" 
                       value="@(Model.Einddatum?.ToString("yyyy-MM-dd") ?? "")" />
            </label>
            <button type="submit">Toon grafiek</button>
        </div>
    </form>
</div>

@if (Model.Data is not null)
{
    <div id="weatherResult">
        <div class="weather-grid">
            <div class="weather-item">
                <img src="~/actuele_temperatuur.svg" alt="Temperatuur" height="52" />
                <div class="weather-text">
                    <span class="value">@Model.Data.ActueleTemperatuur</span>
                    <p class="label">Actuele temperatuur</p>
                </div>
            </div>
            <div class="weather-item">
                <img src="~/zonnekracht.svg" alt="Zonnekracht" height="52" />
                <div class="weather-text">
                    <span class="value">@Model.Data.Zonnekracht</span>
                    <p class="label">Zonnekracht</p>
                </div>
            </div>
            <div class="weather-item">
                <img src="~/gevoelstemperatuur.svg" alt="Gevoelstemperatuur" height="52" />
                <div class="weather-text">
                    <span class="value">@Model.Data.Gevoelstemperatuur</span>
                    <p class="label">Gevoelstemperatuur</p>
                </div>
            </div>
            <div class="weather-item">
                <img src="~/regen_laatste_uur.svg" alt="Regen" height="52" />
                <div class="weather-text">
                    <span class="value">@Model.Data.RegenLaatsteUur mm</span>
                    <p class="label">Regen laatste uur</p>
                </div>
            </div>
            <div class="weather-item">
                <img src="~/grondtemperatuur.svg" alt="Grond temperatuur" height="52" />
                <div class="weather-text">
                    <span class="value">@Model.Data.GrondTemperatuur</span>
                    <p class="label">Grond temperatuur</p>
                </div>
            </div>
            <div class="weather-item">
                <img src="~/windrichting.svg" alt="Windrichting" height="52" />
                <div class="weather-text">
                    <span class="value">@Model.Data.Windrichting</span>
                    <p class="label">Windrichting</p>
                </div>
            </div>
        </div>
    </div>
}

@* New — graph section *@
@if (Model.HistoricalData.Count > 0)
{
    <div class="graph-section">
        <h3>Temperatuur over periode</h3>
        <canvas id="weatherChart"></canvas>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const labels = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
            Enumerable.Range(1, Model.HistoricalData.Count)
                      .Select(i => i.ToString())
                      .ToList()
        ));

        const temperatures = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
            Model.HistoricalData.Select(d => d.ActueleTemperatuur).ToList()
        ));

        const ctx = document.getElementById('weatherChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Actuele temperatuur (°C)',
                    data: temperatures,
                    borderColor: '#4AD6ED',
                    backgroundColor: 'rgba(74, 214, 237, 0.1)',
                    tension: 0.3,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: true }
                },
                scales: {
                    y: { beginAtZero: false }
                }
            }
        });
    </script>
}
else if (!string.IsNullOrWhiteSpace(Model.SelectedCity))
{
    <p style="text-align:center;">Geen gegevens gevonden voor "@Model.SelectedCity".</p>
}